# Per-curriculum build settings. Copy into the curriculum repo root and edit.
# `: "${KEY:=value}"` = use this unless already set in the environment.

# AsciiDoc root in docs/ (no .adoc); also the output file name.
# REQUIRED — there is no default; the build fails if it is unset. Set it in the
# curriculum repo (uncomment below) or pass it as `-e CURRICULUM_FILE=...`.
# : "${CURRICULUM_FILE:=my-curriculum}"

# Space-separated languages to build.
: "${LANGUAGES:=DE EN}"

# Space-separated extra variants, exposed as the {suffix} attribute. Empty = single build.
: "${SUFFIX_TAGS:=}"

# PDF print/book layout (recto chapter starts + binding margins). true | false.
: "${PREPRESS:=false}"
