# Per-curriculum build settings. Copy into the curriculum repo root and edit.
# `: "${KEY:=value}"` = use this unless already set in the environment.

# AsciiDoc root in docs/ (no .adoc); also the output file name.
# REQUIRED — there is no default; the build fails if it is unset. Set it in the
# curriculum repo (uncomment below) or pass it as `-e CURRICULUM_FILE=...`.
# : "${CURRICULUM_FILE:=my-curriculum}"

# Space-separated languages to build.
: "${LANGUAGES:=DE EN}"

# Space-separated extra variants, exposed as the {suffix} attribute. Empty = single build.
: "${SUFFIX_TAGS:=}"

# PDF print/book layout (recto chapter starts + binding margins). true | false.
: "${PREPRESS:=false}"

# Optional curriculum validity date, format YYYY/MM/DD (e.g. 2025/04/01).
# When set, appended to {document-version} as " (valid from April 1, 2025)" /
# " (Gültig ab 1. April 2025)" per language. Invalid format is ignored.
# : "${VALID_FROM:=2025/04/01}"

# Extra CLI flags passed through to the asciidoctor / asciidoctor-pdf commands.
# Space-separated, word-split (no quoting/spaces inside a single arg). E.g. --trace.
# _COMMON_ applies to both formats; the others are format-specific and appended after it.
# : "${ASCIIDOCTOR_COMMON_OPTS:=--trace}"
# : "${ASCIIDOCTOR_PDF_OPTS:=}"
# : "${ASCIIDOCTOR_HTML_OPTS:=}"
