{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["local>isaqb-org/renovate-config"],
  "customManagers": [
    {
      "customType": "regex",
      "description": "Pinned asciidoctor gems in the Dockerfile (the base image is handled by the built-in Docker manager).",
      "managerFilePatterns": ["/(^|/)Dockerfile$/"],
      "matchStrings": ["(?<depName>asciidoctor[a-z-]*):(?<currentValue>[0-9][0-9.]+)"],
      "datasourceTemplate": "rubygems"
    },
    {
      "customType": "regex",
      "description": "Theme repos cloned in the Dockerfile, pinned to a main commit and bumped via the git-refs datasource.",
      "managerFilePatterns": ["/(^|/)Dockerfile$/"],
      "matchStrings": [
        "ARG \\w+_THEME_REPO=(?<packageName>\\S+)\\s+#\\s*renovate:\\s*currentValue=(?<currentValue>\\S+)\\s+ARG \\w+_THEME_REF=(?<currentDigest>[a-f0-9]{40})"
      ],
      "datasourceTemplate": "git-refs",
      "depNameTemplate": "{{packageName}}"
    }
  ]
}
